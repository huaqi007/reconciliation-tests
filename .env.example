# ============================================================
# 对账环境配置
# 代码完全一样，只换下面三个变量，就能在三个环境跑
# cp .env.example .env → 填上真实值 → 运行
# ============================================================

# ─── 本地环境（anvil，开发调试用）──────────────────────────
# RPC_URL=http://127.0.0.1:8555
# DATABASE_URL=postgres://indexer:indexer123@localhost:5432/indexer_db
# CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
# FROM_BLOCK=0

# ─── Sepolia 测试网（上线前验证）───────────────────────────
# RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
# DATABASE_URL=postgres://indexer:indexer123@your-staging-db:5432/indexer_db
# CONTRACT_ADDRESS=0x你在Sepolia上部署的SimpleToken地址
# FROM_BLOCK=0

# ─── 生产主网（线上持续监控）────────────────────────────────
# RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
# DATABASE_URL=postgres://indexer:indexer123@your-prod-db:5432/indexer_db
# CONTRACT_ADDRESS=0x你在主网上的SimpleToken地址
# FROM_BLOCK=0
